{
  "manifest_version": 3,
  "name": "Made-in-China Bulk Fill",
  "description": "Paste product information once and fill matching Made-in-China product upload fields.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Bulk Fill",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "clipboardRead",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.made-in-china.com/*",
    "*://*.made-in-china.cn/*",
    "*://*.made-in-china.com.cn/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.made-in-china.com/*",
        "*://*.made-in-china.cn/*",
        "*://*.made-in-china.com.cn/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
